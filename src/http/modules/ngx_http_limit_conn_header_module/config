# Defines the official and internal name of our module for the NGINX build process
ngx_addon_name=ngx_http_limit_conn_header_module

# Adds our module to the list שof existing HTTP modules.
# This tells NGINX that this module handles web requests (HTTP context).
HTTP_MODULES="$HTTP_MODULES ngx_http_limit_conn_header_module"

# Instructs the compiler where to find the source code (C logic) to compile into the server.
# $ngx_addon_dir is automatically translated to the current directory of this config file.
NGX_ADDON_SRCS="$NGX_ADDON_SRCS $ngx_addon_dir/ngx_http_limit_conn_header_module.c"